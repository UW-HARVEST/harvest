{
  "name": "project_spec",
  "schema": {
    "type": "object",
    "properties": {
      "targets": {
        "type": "array",
        "description": "Ordered list of targets in compile/link order.",
        "items": {
          "type": "object",
          "properties": {
            "name": {
              "type": "string"
            },
            "artifact": {
              "type": "string"
            },
            "kind": {
              "type": "string",
              "enum": ["Library", "Executable"]
            },
            "sources": {
              "type": "array",
              "items": {
                "type": "string",
                "pattern": ".*\\.(c|h)$"
              }
            },
            "deps": {
              "type": "array",
              "description": "Direct logical CMake target dependencies by target name.",
              "items": {
                "type": "string"
              }
            }
          },
          "required": ["name", "artifact", "kind", "sources", "deps"]
        }
      }
    },
    "required": ["targets"]
  }
}
